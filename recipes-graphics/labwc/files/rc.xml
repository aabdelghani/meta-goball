<?xml version="1.0" encoding="UTF-8"?>
<labwc_config>
  <core>
    <gap>0</gap>
    <decoration>none</decoration>
  </core>
  <theme>
    <name></name>
    <titlebar>
      <height>0</height>
    </titlebar>
  </theme>
  <focus>
    <followMouse>no</followMouse>
    <raiseOnFocus>no</raiseOnFocus>
  </focus>
  <windowRules>
    <!-- mpv: no decorations, always on top, fixed position -->
    <windowRule identifier="mpv" serverDecoration="no" skipTaskbar="yes" fixedPosition="yes" ignoreFocusRequest="yes">
      <action name="ToggleAlwaysOnTop"/>
    </windowRule>
    <!-- goball/LVGL: maximize, no decorations -->
    <windowRule identifier="goball" serverDecoration="no" skipTaskbar="yes">
      <action name="Maximize"/>
    </windowRule>
  </windowRules>
  <!-- Hide cursor immediately (kiosk/touchscreen mode) -->
  <cursor>
    <hide>0</hide>
  </cursor>
  <!-- Kiosk mode: no keyboard shortcuts for window management -->
  <keyboard>
  </keyboard>
  <!-- Kiosk mode: focus only on touch, no raise (prevents ffplay going behind) -->
  <mouse>
    <context name="Client">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
      </mousebind>
    </context>
  </mouse>
</labwc_config>
