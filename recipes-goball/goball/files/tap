#!/usr/bin/python3
import struct, fcntl, os, sys, time

UI_SET_EVBIT  = 0x40045564
UI_SET_KEYBIT = 0x40045565
UI_SET_ABSBIT = 0x40045567
UI_DEV_CREATE = 0x5501
UI_DEV_DESTROY= 0x5502

EV_SYN, EV_KEY, EV_ABS = 0, 1, 3
ABS_X, ABS_Y = 0, 1
BTN_TOUCH = 0x14a

# Named positions
POSITIONS = {
    "quota_points": (1350, 400),
    "eight_points": (427, 360),
    "player1_edit": (427, 360),
    "comma": (2300, 600),
    "edit_confirm": (2480, 680),
    "main_menu": (100, 100),
}

if len(sys.argv) > 1 and sys.argv[1] in POSITIONS:
    x, y = POSITIONS[sys.argv[1]]
elif len(sys.argv) > 2:
    x, y = int(sys.argv[1]), int(sys.argv[2])
else:
    print("Usage: tap <x> <y>  OR  tap <name>")
    print("Named positions:")
    for name, (px, py) in POSITIONS.items():
        print(f"  {name}: ({px}, {py})")
    sys.exit(1)

fd = os.open("/dev/uinput", os.O_WRONLY | os.O_NONBLOCK)
fcntl.ioctl(fd, UI_SET_EVBIT, EV_KEY)
fcntl.ioctl(fd, UI_SET_EVBIT, EV_ABS)
fcntl.ioctl(fd, UI_SET_KEYBIT, BTN_TOUCH)
fcntl.ioctl(fd, UI_SET_ABSBIT, ABS_X)
fcntl.ioctl(fd, UI_SET_ABSBIT, ABS_Y)

name = b"virtual-touch" + b"\0" * 67
ids = struct.pack("HHHH", 0, 0, 0, 0)
ff = struct.pack("i", 0)
absmax = [0] * 64
absmin = [0] * 64
absfuzz = [0] * 64
absflat = [0] * 64
absmax[ABS_X] = 2560
absmax[ABS_Y] = 720
absmax_b = struct.pack("64i", *absmax)
absmin_b = struct.pack("64i", *absmin)
absfuzz_b = struct.pack("64i", *absfuzz)
absflat_b = struct.pack("64i", *absflat)
dev = name + ids + ff + absmax_b + absmin_b + absfuzz_b + absflat_b
os.write(fd, dev)
fcntl.ioctl(fd, UI_DEV_CREATE)
time.sleep(0.5)

def write_event(t, c, v):
    ev = struct.pack("QQHHi", 0, 0, t, c, v)
    os.write(fd, ev)

write_event(EV_ABS, ABS_X, x)
write_event(EV_ABS, ABS_Y, y)
write_event(EV_KEY, BTN_TOUCH, 1)
write_event(EV_SYN, 0, 0)
time.sleep(0.05)

write_event(EV_KEY, BTN_TOUCH, 0)
write_event(EV_SYN, 0, 0)
time.sleep(0.1)

fcntl.ioctl(fd, UI_DEV_DESTROY)
os.close(fd)
print(f"Tapped at ({x}, {y})")
